---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategorySection from '../../components/CategorySection.astro';
import SkillTree from '../../components/SkillTree.astro';
import { MICROSERVICES_CATEGORIES } from '../../lib/consts';

const topics = await getCollection('microservices');
const sorted = [...topics].sort((a, b) => a.data.order - b.data.order);
const first = sorted[0];
const slugs = topics.filter((t) => t.data.kind !== 'pattern').map((t) => t.id).join(',');
---
<BaseLayout title="Microservices" description="Services modeled around business domains and independently deployable — foundations and trade-offs, decomposing a monolith, communication and distributed workflow with sagas, building and operating at scale, and the team topologies that make it work. Based on Building Microservices, Monolith to Microservices and Enabling Microservice Success.">
  <nav class="dp-breadcrumb dp-kicker"><a href="/">The Architecture Reference</a> › <span>Microservices</span></nav>

  <header class="dp-hero">
    <p class="dp-hero__eyebrow" data-i18n="microservices.eyebrow">Independent services</p>
    <h1 data-i18n="microservices.h1">Microservices</h1>
    <p class="dp-hero__lede" data-i18n-html="microservices.lede">
      Microservices are services <strong>independently deployable</strong> and modeled around a business domain. They buy autonomy and scale — at a real cost in operational and cognitive complexity. This track covers when they pay off, how to <strong>decompose</strong> a monolith safely, how services <strong>communicate</strong>, and how teams own them.
    </p>
    {first && (
      <div class="dp-hero__cta">
        <a class="dp-btn dp-btn--primary" href={`/microservices/${first.id}/`} data-i18n="ui.startJourney">Start the journey →</a>
      </div>
    )}
  </header>

  <div class="dp-overall">
    <div class="dp-overall__top">
      <strong data-i18n="microservices.progressTitle">Your microservices progress</strong>
      <button class="dp-btn dp-btn--ghost dp-btn--sm" data-dp-reset data-i18n="ui.reset">Reset</button>
    </div>
    <div class="dp-progress" data-dp-progress data-slugs={slugs}>
      <div class="dp-progress__track"><div class="dp-progress__fill"></div></div>
      <span class="dp-progress__label"></span>
    </div>
    <p class="dp-kicker" style="margin:.7rem 0 0;" data-i18n="track.progressNote">Mark a topic “learned” on its page and watch the bars fill.</p>
  </div>

  <SkillTree entries={topics} categories={MICROSERVICES_CATEGORIES} base="/microservices" />

  {MICROSERVICES_CATEGORIES.map((c) => (
    <CategorySection cat={c.key} title={c.title} blurb={c.blurb} collection="microservices" base="/microservices" />
  ))}

  <div class="dp-callout dp-callout--go" style="margin-top:2.6rem;">
    <p class="dp-callout__title" data-i18n="microservices.callout.title">🔪 Migrate incrementally — never big-bang rewrite</p>
    <p data-i18n-html="microservices.callout.body">The reliable path to microservices is to keep the monolith running and peel services off one at a time, behind patterns like the strangler fig, branch-by-abstraction and parallel run. Each step delivers value and is reversible. A big-bang rewrite trades a working system for months of risk.</p>
  </div>
</BaseLayout>
