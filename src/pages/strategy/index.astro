---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategorySection from '../../components/CategorySection.astro';
import SkillTree from '../../components/SkillTree.astro';
import { STRATEGY_CATEGORIES } from '../../lib/consts';

const topics = await getCollection('strategy');
const sorted = [...topics].sort((a, b) => a.data.order - b.data.order);
const first = sorted[0];
const slugs = topics.filter((t) => t.data.kind !== 'pattern').map((t) => t.id).join(',');
---
<BaseLayout title="The Architect's Path" description="The architect as a person and strategist — riding the “architect elevator” between the boardroom and the engine room, patterns for analyzing, creating and communicating technology strategy, and systems thinking for complex sociotechnical systems. Based on The Software Architect Elevator, Technology Strategy Patterns and Learning Systems Thinking.">
  <nav class="dp-breadcrumb dp-kicker"><a href="/">The Architecture Reference</a> › <span>The Architect's Path</span></nav>

  <header class="dp-hero">
    <p class="dp-hero__eyebrow" data-i18n="strategy.eyebrow">The craft & the career</p>
    <h1 data-i18n="strategy.h1">The Architect’s Path</h1>
    <p class="dp-hero__lede" data-i18n-html="strategy.lede">
      Great architecture is as much about <strong>people and decisions</strong> as boxes and lines. This track is about the architect’s craft: riding the <strong>elevator</strong> between business and tech, building and communicating <strong>technology strategy</strong>, and using <strong>systems thinking</strong> to reason about feedback loops and leverage in complex organizations.
    </p>
    {first && (
      <div class="dp-hero__cta">
        <a class="dp-btn dp-btn--primary" href={`/strategy/${first.id}/`} data-i18n="ui.startJourney">Start the journey →</a>
      </div>
    )}
  </header>

  <div class="dp-overall">
    <div class="dp-overall__top">
      <strong data-i18n="strategy.progressTitle">Your the architect's path progress</strong>
      <button class="dp-btn dp-btn--ghost dp-btn--sm" data-dp-reset data-i18n="ui.reset">Reset</button>
    </div>
    <div class="dp-progress" data-dp-progress data-slugs={slugs}>
      <div class="dp-progress__track"><div class="dp-progress__fill"></div></div>
      <span class="dp-progress__label"></span>
    </div>
    <p class="dp-kicker" style="margin:.7rem 0 0;" data-i18n="track.progressNote">Mark a topic “learned” on its page and watch the bars fill.</p>
  </div>

  <SkillTree entries={topics} categories={STRATEGY_CATEGORIES} base="/strategy" />

  {STRATEGY_CATEGORIES.map((c) => (
    <CategorySection cat={c.key} title={c.title} blurb={c.blurb} collection="strategy" base="/strategy" />
  ))}

  <div class="dp-callout dp-callout--go" style="margin-top:2.6rem;">
    <p class="dp-callout__title" data-i18n="strategy.callout.title">🛗 An architect connects the penthouse to the engine room</p>
    <p data-i18n-html="strategy.callout.body">The unique value of an architect isn’t living on one floor — it’s riding the elevator: translating business strategy into technical decisions and surfacing technical realities into business choices. The higher the building (the bigger the org), the more valuable that ride, and the more tempting it is to get stuck on one floor.</p>
  </div>
</BaseLayout>
