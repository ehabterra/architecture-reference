---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategorySection from '../../components/CategorySection.astro';
import SkillTree from '../../components/SkillTree.astro';
import { STYLES_CATEGORIES } from '../../lib/consts';

const topics = await getCollection('styles');
const sorted = [...topics].sort((a, b) => a.data.order - b.data.order);
const first = sorted[0];
const slugs = topics.filter((t) => t.data.kind !== 'pattern').map((t) => t.id).join(',');
---
<BaseLayout title="Architecture Styles" description="The named shapes a system can take — layered, pipeline, microkernel, service-based, event-driven, space-based and microservices — each with its topology, its strengths, and the characteristics it optimizes for. Based on Software Architecture Patterns and Fundamentals of Software Architecture.">
  <nav class="dp-breadcrumb dp-kicker"><a href="/">The Architecture Reference</a> › <span>Architecture Styles</span></nav>

  <header class="dp-hero">
    <p class="dp-hero__eyebrow" data-i18n="styles.eyebrow">Topologies</p>
    <h1 data-i18n="styles.h1">Architecture Styles</h1>
    <p class="dp-hero__lede" data-i18n-html="styles.lede">
      A style is the overall <strong>topology</strong> of a system — how its parts are partitioned and deployed. This track walks the major styles from the simple <strong>monolithic</strong> shapes to the <strong>distributed</strong> ones, scoring each against the architecture characteristics so you can choose with eyes open.
    </p>
    {first && (
      <div class="dp-hero__cta">
        <a class="dp-btn dp-btn--primary" href={`/styles/${first.id}/`} data-i18n="ui.startJourney">Start the journey →</a>
      </div>
    )}
  </header>

  <div class="dp-overall">
    <div class="dp-overall__top">
      <strong data-i18n="styles.progressTitle">Your architecture styles progress</strong>
      <button class="dp-btn dp-btn--ghost dp-btn--sm" data-dp-reset data-i18n="ui.reset">Reset</button>
    </div>
    <div class="dp-progress" data-dp-progress data-slugs={slugs}>
      <div class="dp-progress__track"><div class="dp-progress__fill"></div></div>
      <span class="dp-progress__label"></span>
    </div>
    <p class="dp-kicker" style="margin:.7rem 0 0;" data-i18n="track.progressNote">Mark a topic “learned” on its page and watch the bars fill.</p>
  </div>

  <SkillTree entries={topics} categories={STYLES_CATEGORIES} base="/styles" />

  {STYLES_CATEGORIES.map((c) => (
    <CategorySection cat={c.key} title={c.title} blurb={c.blurb} collection="styles" base="/styles" />
  ))}

  <div class="dp-callout dp-callout--go" style="margin-top:2.6rem;">
    <p class="dp-callout__title" data-i18n="styles.callout.title">🧭 Pick the style that fits the forces, not the fashion</p>
    <p data-i18n-html="styles.callout.body">Every style is strong at some characteristics and weak at others. A modular monolith is simpler and cheaper; microservices buy independent deployability and scale at a steep operational price. Match the style to your real drivers — team size, scale, change cadence — and resist distributing by default.</p>
  </div>
</BaseLayout>
