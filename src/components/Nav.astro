---
import { REPO_URL } from '../lib/consts';
---
<header class="dp-nav" id="dp-nav">
  <div class="dp-container dp-nav__inner">
    <a class="dp-brand" href="/">
      <span class="dp-brand__mark">{'⌘'}</span>
      <span>The Architecture Reference</span>
    </a>

    <nav class="dp-nav__links" id="dp-nav-links">
      <div class="dp-nav__group">
        <button class="dp-nav__trigger" aria-haspopup="true" aria-expanded="false">
          <span data-i18n="nav.tracks">Tracks</span>
          <svg class="dp-nav__caret" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </button>
        <div class="dp-nav__menu">
          <a href="/foundations/" data-i18n="nav.foundations">Foundations</a>
          <a href="/styles/" data-i18n="nav.styles">Architecture Styles</a>
          <a href="/ddd/" data-i18n="nav.ddd">Domain-Driven Design</a>
          <a href="/microservices/" data-i18n="nav.microservices">Microservices</a>
          <a href="/event-driven/" data-i18n="nav.eventdriven">Event-Driven</a>
          <a href="/distributed-systems/" data-i18n="nav.distributed">Distributed Systems</a>
          <a href="/apis/" data-i18n="nav.apis">APIs &amp; Communication</a>
          <a href="/cloud/" data-i18n="nav.cloud">Cloud &amp; SaaS</a>
          <a href="/automation/" data-i18n="nav.automation">Process Automation</a>
          <a href="/strategy/" data-i18n="nav.strategy">The Architect's Path</a>
        </div>
      </div>
      <a href="/glossary/" data-i18n="nav.glossary">Glossary</a>
      <a href="/review/" data-i18n="nav.review">Review</a>
      <a href={REPO_URL} target="_blank" rel="noopener">GitHub ↗</a>
    </nav>

    <div class="dp-nav__actions">
      <button class="dp-lang-btn" data-dp-theme aria-label="Toggle light / dark theme" title="Toggle light / dark theme">☀️</button>
      <button class="dp-account-btn" data-dp-account-btn aria-haspopup="dialog" title="Sync your progress and likes across devices">
        ⇅ <span data-dp-account-label data-i18n="nav.sync">Sync</span>
      </button>
      <button class="dp-lang-btn" data-dp-lang aria-label="Switch language / تبديل اللغة">عربي</button>
      <button class="dp-search-btn" data-dp-search aria-label="Search (Cmd K)">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <span class="dp-search-btn__label" data-i18n="nav.search">Search</span>
        <kbd>⌘K</kbd>
      </button>
      <button class="dp-menu-btn" data-dp-menu aria-label="Menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="7" x2="20" y2="7"></line><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="17" x2="20" y2="17"></line></svg>
      </button>
    </div>
  </div>

  <dialog class="dp-account" data-dp-account>
    <h3 class="dp-account__title" data-i18n="account.title">Sync across devices</h3>
    <p class="dp-account__desc" data-i18n="account.desc">
      Add your email to keep your learning progress and likes with you on any device.
      No account and no emails from us — your address is never saved anywhere: it stays
      in this browser, and only an anonymous fingerprint of it is used.
    </p>
    <p class="dp-account__status" data-dp-account-status hidden>
      <span data-i18n="account.syncingAs">Currently syncing as</span>
      <strong data-dp-account-email></strong>
    </p>
    <form class="dp-account__form" data-dp-account-form>
      <input type="email" required placeholder="you@example.com" aria-label="Your email" />
      <div class="dp-account__row">
        <button type="submit" class="dp-btn dp-btn--sm dp-btn--primary" data-i18n="account.save">Save</button>
        <button type="button" class="dp-btn dp-btn--sm dp-btn--ghost" data-dp-account-cancel data-i18n="account.cancel">Cancel</button>
        <button type="button" class="dp-btn dp-btn--sm dp-btn--ghost dp-account__remove" data-dp-account-remove hidden data-i18n="account.remove">Remove from this browser</button>
      </div>
    </form>
  </dialog>
</header>
